# ✅ 5. LOGISTIC REGRESSION (User Defined – Short)

```python
import numpy as np
import matplotlib.pyplot as plt

x = np.random.rand(100)
y = (x > 0.5).astype(int)

def sigmoid(z):
    return 1/(1+np.exp(-z))

b0,b1 = 0,0
lr = 0.1

for _ in range(500):
    y_pred = sigmoid(b0 + b1*x)
    b0 -= lr*(y_pred-y).mean()
    b1 -= lr*((y_pred-y)*x).mean()

y_class = (sigmoid(b0+b1*x) > 0.5).astype(int)

plt.scatter(x,y,label="Actual")
plt.scatter(x,y_class,label="Predicted")
plt.legend()
plt.show()

print("b0:", b0, "b1:", b1)
```

