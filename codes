# ✅ 1. PREPROCESSING (Simple + Complete)

```python
import pandas as pd
from sklearn.preprocessing import MinMaxScaler, Normalizer, Binarizer, StandardScaler

# Load data
df = pd.read_csv("pima-indians-diabetes.csv")
X = df.values

# 1. Scaling
scaler = MinMaxScaler()
scaled = scaler.fit_transform(X)
print("Scaled Data:\n", scaled[:5])

# 2. Normalization
norm = Normalizer()
normalized = norm.fit_transform(X)
print("\nNormalized Data:\n", normalized[:5])

# 3. Binarization
binarizer = Binarizer(threshold=0.5)
binary = binarizer.fit_transform(X)
print("\nBinarized Data:\n", binary[:5])

# 4. Standardization
std = StandardScaler()
standard = std.fit_transform(X)
print("\nStandardized Data:\n", standard[:5])
```

